{
  "name": "@chaandui/media",
  "version": "0.0.1",
  "description": "Premium media components for ChaandUI",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./video-player": {
      "types": "./dist/video-player/VideoPlayer.d.ts",
      "import": "./dist/video-player/VideoPlayer.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@chaandui/typescript-config": "workspace:*",
    "@chaandui/primitives": "workspace:*",
    "@chaandui/styles": "workspace:*",
    "@chaandui/tokens": "workspace:*",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "peerDependencies": {
    "react": ">=16.8.0"
  }
}
